#!/bin/bash

# === ЦВЕТА ===
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
NC='\033[0m'

# === НАСТРОЙКИ ===
REPO_URL="https://github.com/jestivald/node-accelerator.git"
INSTALL_DIR="/opt/node-accelerator"

# === ФУНКЦИИ ===

print_header() {
    clear
    echo -e "${CYAN}${BOLD}"
    echo "╔═══════════════════════════════════════════════════════════════╗"
    echo "║         ⚡ Node Accelerator - Лаунчер скриптов ⚡            ║"
    echo "╚═══════════════════════════════════════════════════════════════╝"
    echo -e "${NC}"
}

check_root() {
    if [ "$EUID" -ne 0 ]; then 
        echo -e "${RED}Ошибка: Этот скрипт требует прав root (sudo)${NC}"
        exit 1
    fi
}

clone_or_update_repo() {
    echo -e "${BLUE}Проверка репозитория...${NC}"
    
    if [ ! -d "$INSTALL_DIR" ]; then
        echo -e "${YELLOW}Клонирование репозитория в $INSTALL_DIR...${NC}"
        git clone "$REPO_URL" "$INSTALL_DIR"
        if [ $? -ne 0 ]; then
            echo -e "${RED}Ошибка: Не удалось клонировать репозиторий${NC}"
            exit 1
        fi
        echo -e "${GREEN}✓ Репозиторий клонирован${NC}"
    else
        echo -e "${YELLOW}Обновление репозитория...${NC}"
        cd "$INSTALL_DIR"
        git pull
        if [ $? -eq 0 ]; then
            echo -e "${GREEN}✓ Репозиторий обновлен${NC}"
        else
            echo -e "${YELLOW}Не удалось обновить репозиторий, используем локальную версию${NC}"
        fi
    fi
    echo ""
}

show_menu() {
    echo -e "${BOLD}Выберите действие:${NC}"
    echo ""
    echo -e "${GREEN}1.${NC} ⚡  ${BOLD}Установить всё${NC} (optimize + protect + diagnose)"
    echo -e "${GREEN}2.${NC} ⚡  ${BOLD}Оптимизация${NC} (XanMod + BBRv3 + sysctl tuning)"
    echo -e "${GREEN}3.${NC} 🛡  ${BOLD}Защита${NC} (nftables + CrowdSec + anti-scan)"
    echo -e "${GREEN}4.${NC} 🩺 ${BOLD}Диагностика${NC} (health-check отчёт)"
    echo -e "${GREEN}5.${NC} 🔥 ${BOLD}Форензика атак${NC} (кто/откуда/чем атаковали)"
    echo ""
    echo -e "${CYAN}6.${NC} 📊 ${BOLD}Статус файрвола${NC} (na-fw-status)"
    echo -e "${CYAN}7.${NC} 📈 ${BOLD}Топ источников${NC} (na-fw-top-talkers)"
    echo -e "${CYAN}8.${NC} 🔍 ${BOLD}Диагностика JSON${NC} (для мониторинга)"
    echo -e "${CYAN}9.${NC} 🔬 ${BOLD}Анализ TCP retransmits${NC} (причины потерь)"
    echo ""
    echo -e "${YELLOW}10.${NC} 🔄 ${BOLD}Переустановить репозиторий${NC}"
    echo -e "${RED}0.${NC}  ${BOLD}Выход${NC}"
    echo ""
    echo -ne "${BOLD}Ваш выбор [0-10]: ${NC}"
}

run_script() {
    local script_path="$1"
    local description="$2"
    
    echo ""
    echo -e "${BLUE}═══════════════════════════════════════════════════════════════${NC}"
    echo -e "${BOLD}Запуск: $description${NC}"
    echo -e "${BLUE}═══════════════════════════════════════════════════════════════${NC}"
    echo ""
    
    cd "$INSTALL_DIR" || exit 1
    
    if [ ! -f "$script_path" ]; then
        echo -e "${RED}Ошибка: Скрипт $script_path не найден${NC}"
        echo -e "${YELLOW}Возможно, нужно сначала установить модуль через меню${NC}"
        echo ""
        read -p "Нажмите Enter для продолжения..."
        return 1
    fi
    
    bash "$script_path"
    local exit_code=$?
    
    echo ""
    echo -e "${BLUE}═══════════════════════════════════════════════════════════════${NC}"
    if [ $exit_code -eq 0 ]; then
        echo -e "${GREEN}✓ Скрипт завершён успешно${NC}"
    else
        echo -e "${RED}✘ Скрипт завершился с кодом ошибки: $exit_code${NC}"
    fi
    echo -e "${BLUE}═══════════════════════════════════════════════════════════════${NC}"
    echo ""
    read -p "Нажмите Enter для продолжения..."
}

run_command() {
    local command="$1"
    local description="$2"
    
    echo ""
    echo -e "${BLUE}═══════════════════════════════════════════════════════════════${NC}"
    echo -e "${BOLD}Выполнение: $description${NC}"
    echo -e "${BLUE}═══════════════════════════════════════════════════════════════${NC}"
    echo ""
    
    if ! command -v "$command" &> /dev/null; then
        echo -e "${RED}Ошибка: Команда '$command' не найдена${NC}"
        echo -e "${YELLOW}Возможно, нужно сначала установить модуль через меню${NC}"
        echo ""
        read -p "Нажмите Enter для продолжения..."
        return 1
    fi
    
    $command
    local exit_code=$?
    
    echo ""
    echo -e "${BLUE}═══════════════════════════════════════════════════════════════${NC}"
    if [ $exit_code -eq 0 ]; then
        echo -e "${GREEN}✓ Команда выполнена успешно${NC}"
    else
        echo -e "${RED}✘ Команда завершилась с кодом ошибки: $exit_code${NC}"
    fi
    echo -e "${BLUE}═══════════════════════════════════════════════════════════════${NC}"
    echo ""
    read -p "Нажмите Enter для продолжения..."
}

reinstall_repo() {
    echo ""
    echo -e "${YELLOW}Удаление старой версии репозитория...${NC}"
    rm -rf "$INSTALL_DIR"
    echo -e "${GREEN}✓ Удалено${NC}"
    echo ""
    clone_or_update_repo
    read -p "Нажмите Enter для продолжения..."
}

# === ОСНОВНОЙ ЦИКЛ ===

check_root
clone_or_update_repo

while true; do
    print_header
    show_menu
    read -r choice
    
    case $choice in
        1)
            run_script "install.sh" "Установка всех модулей (optimize + protect + diagnose)"
            ;;
        2)
            run_script "install.sh optimize" "Установка модуля оптимизации"
            ;;
        3)
            run_script "install.sh protect" "Установка модуля защиты"
            ;;
        4)
            run_command "na-diagnose" "Диагностика системы"
            ;;
        5)
            run_command "na-report" "Форензика атак за последние 24 часа"
            ;;
        6)
            run_command "na-fw-status" "Статус файрвола"
            ;;
        7)
            run_command "na-fw-top-talkers" "Топ источников трафика"
            ;;
        8)
            run_command "na-diagnose --json" "Диагностика в формате JSON"
            ;;
        9)
            run_command "na-diagnose --retrans" "Анализ TCP retransmits"
            ;;
        10)
            reinstall_repo
            ;;
        0)
            echo ""
            echo -e "${GREEN}До свидания!${NC}"
            exit 0
            ;;
        *)
            echo ""
            echo -e "${RED}Неверный выбор. Попробуйте снова.${NC}"
            sleep 1
            ;;
    esac
done